<?xml version="1.0" encoding="utf-8"?>
<!--
    Elyra settings hero card — "Pusat Elyra".
    Inflated by ElyraSettingsHeroController via setLayoutResource().
    Replaces AndroidX preference chrome entirely.

    Contains only real, non-fake content:
      - Info pill (branding label)
      - Title: Pusat Elyra
      - Rotating description (5 strings, swaps every 4 s)

    Quick-action buttons (Cuaca/Notifikasi/Lokasi) that scrolled to hidden
    preference categories have been removed. Fake static weather preview
    has been removed. These will be re-added when the backing features are real.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/elyra_hero_card_margin_horizontal"
    android:paddingEnd="@dimen/elyra_hero_card_margin_horizontal"
    android:paddingTop="12dp"
    android:paddingBottom="8dp">

    <!-- Gradient hero card surface -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/elyra_hero_card_bg"
        android:paddingStart="@dimen/elyra_hero_card_padding"
        android:paddingEnd="@dimen/elyra_hero_card_padding"
        android:paddingTop="@dimen/elyra_hero_card_padding"
        android:paddingBottom="@dimen/elyra_hero_card_padding">

        <!-- Info pill: branding chip above the title -->
        <TextView
            android:id="@+id/elyra_hero_info_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/elyra_hero_info_pill"
            android:textSize="10sp"
            android:textColor="#B3FFFFFF"
            android:letterSpacing="0.05"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/elyra_info_pill_bg"
            android:layout_marginBottom="10dp" />

        <!-- Title: Pusat Elyra -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/elyra_hero_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="8dp" />

        <!-- Rotating description: controlled by ElyraSettingsHeroController -->
        <TextView
            android:id="@+id/elyra_hero_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/elyra_hero_desc_1"
            android:textSize="13sp"
            android:textColor="#B3FFFFFF"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

</LinearLayout>
