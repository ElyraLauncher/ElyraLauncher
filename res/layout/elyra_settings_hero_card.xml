<?xml version="1.0" encoding="utf-8"?>
<!--
    Elyra settings hero card — top of the settings screen.
    Inflated by ElyraHeroCardPreference via setLayoutResource().
    No AndroidX preference chrome — the whole item is this layout.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="4dp">

    <!-- Hero card surface -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/elyra_hero_card_bg"
        android:padding="20dp"
        android:gravity="center_vertical">

        <!-- Left content: title + info pill + description + quick actions -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Info pill -->
            <TextView
                android:id="@+id/elyra_hero_info_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/elyra_hero_info_pill"
                android:textSize="10sp"
                android:textColor="#B3FFFFFF"
                android:letterSpacing="0.05"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/elyra_info_pill_bg"
                android:layout_marginBottom="8dp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/elyra_hero_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="6dp" />

            <!-- Rotating description -->
            <TextView
                android:id="@+id/elyra_hero_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/elyra_hero_desc_1"
                android:textSize="12sp"
                android:textColor="#B3FFFFFF"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="16dp" />

            <!-- Quick actions row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start">

                <!-- Cuaca -->
                <LinearLayout
                    android:id="@+id/elyra_action_weather"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/elyra_hero_action_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/elyra_ic_weather"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/elyra_action_weather"
                        android:textSize="10sp"
                        android:textColor="#CCFFFFFF" />
                </LinearLayout>

                <!-- Notifikasi -->
                <LinearLayout
                    android:id="@+id/elyra_action_notification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/elyra_hero_action_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/elyra_ic_notification"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/elyra_action_notification"
                        android:textSize="10sp"
                        android:textColor="#CCFFFFFF" />
                </LinearLayout>

                <!-- Lokasi -->
                <LinearLayout
                    android:id="@+id/elyra_action_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/elyra_hero_action_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/elyra_ic_location"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/elyra_action_location"
                        android:textSize="10sp"
                        android:textColor="#CCFFFFFF" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Right: preview area (weather summary) -->
        <LinearLayout
            android:id="@+id/elyra_hero_preview"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="12dp">

            <ImageView
                android:id="@+id/elyra_hero_preview_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/elyra_ic_weather"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/elyra_hero_preview_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/elyra_hero_preview_temp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF"
                android:gravity="center" />

            <TextView
                android:id="@+id/elyra_hero_preview_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/elyra_hero_preview_condition"
                android:textSize="10sp"
                android:textColor="#80FFFFFF"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
