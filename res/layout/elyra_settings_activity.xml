<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/elyra_settings_bg">

    <!-- Shell header — GONE on dashboard, VISIBLE on detail screens -->
    <LinearLayout
        android:id="@+id/elyra_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:background="@color/elyra_settings_bg">

        <ImageButton
            android:id="@+id/elyra_back"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/elyra_ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/elyra_settings_back"
            android:padding="16dp" />

        <TextView
            android:id="@+id/elyra_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/elyra_hero_text_primary"
            android:paddingEnd="16dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Content container — fragments are placed here -->
    <FrameLayout
        android:id="@+id/elyra_content_frame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
