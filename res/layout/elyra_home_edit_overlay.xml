<?xml version="1.0" encoding="utf-8"?>
<!--
    Elyra Home Edit Mode fullscreen overlay.

    Added directly to DragLayer as a plain (non-floating-view) child; visibility and animation
    are driven by ElyraHomeEditModeController reacting to LauncherState.EDIT_MODE transitions.
    The scaled/dimmed workspace and the dock fade are handled by EditModeState — this overlay
    only supplies the top/bottom chrome plus a dim scrim.

    The middle area is the real Workspace showing through a NON-interactive dim scrim, so the
    user can swipe home pages while editing. Exit is Done / Back only (no tap-to-exit, which
    would consume swipes).

    NOTE: intentionally NO fitsSystemWindows here. The scrim must reach edge-to-edge so the
    dim is one continuous surface with no bands behind the status/navigation bars. The overlay
    is marked ignoreInsets in the controller (DragLayer would otherwise add system-bar insets as
    margins); system-bar insets are instead applied as padding to ONLY the top and bottom bars,
    in ElyraHomeEditModeController#applyWindowInsets.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/elyra_home_edit_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:contentDescription="@string/elyra_home_edit_panel_description"
    android:visibility="gone">

    <!--
        Dim only. Intentionally NOT clickable/focusable so horizontal swipes fall through to the
        real Workspace beneath (which is page-scrollable in EDIT_MODE). A clickable full-screen
        scrim here was the root cause of edit mode not being swipeable.
    -->
    <View
        android:id="@+id/elyra_home_edit_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/elyra_home_edit_scrim" />

    <!--
        Top controls. paddingTop is small on purpose — the status-bar inset is added on top of
        it programmatically (applyWindowInsets), so the pills sit just below the status area
        rather than floating far down the screen.
    -->
    <LinearLayout
        android:id="@+id/elyra_home_edit_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!--
            Group is a placeholder for a not-yet-implemented icon-grouping feature.
            Visually present (per UX spec) but permanently disabled/non-clickable — no fake
            behavior is wired to it. Enable once real grouping exists.
        -->
        <TextView
            android:id="@+id/elyra_home_edit_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="72dp"
            android:minHeight="40dp"
            android:gravity="center"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/elyra_home_edit_group_bg"
            android:clickable="false"
            android:focusable="false"
            android:alpha="0.6"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/materialColorOnSurface"
            android:text="@string/elyra_home_edit_group_button_text" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/elyra_home_edit_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="72dp"
            android:minHeight="40dp"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/elyra_home_edit_done_bg"
            android:foreground="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/materialColorOnPrimary"
            android:text="@string/elyra_home_edit_done_button_text" />
    </LinearLayout>

    <!--
        Bottom edit actions. No card/panel background: the row sits directly over the dim scrim.
        Each action is an equal-weight column with a fixed-size circular icon backdrop and a
        two-line (minLines=2) centered label, so all four icons and labels stay aligned even when
        some labels wrap ("Wallpaper & style" / "Setelan layar utama") and others do not.
    -->
    <LinearLayout
        android:id="@+id/elyra_home_edit_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:paddingTop="18dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_widget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/elyra_home_edit_action_icon_bg">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:tint="@android:color/white"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_elyra_edit_widget" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:maxLines="2"
                android:minLines="2"
                android:lineSpacingMultiplier="1.0"
                android:includeFontPadding="false"
                android:ellipsize="end"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="@string/widget_button_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_wallpaper"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/elyra_home_edit_action_icon_bg">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:tint="@android:color/white"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_elyra_edit_wallpaper" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:maxLines="2"
                android:minLines="2"
                android:lineSpacingMultiplier="1.0"
                android:includeFontPadding="false"
                android:ellipsize="end"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="@string/styles_wallpaper_button_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/elyra_home_edit_action_icon_bg">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:tint="@android:color/white"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_elyra_edit_layout" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:maxLines="2"
                android:minLines="2"
                android:lineSpacingMultiplier="1.0"
                android:includeFontPadding="false"
                android:ellipsize="end"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="@string/elyra_home_edit_layout_button_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/elyra_home_edit_action_icon_bg">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:tint="@android:color/white"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_elyra_edit_settings" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:maxLines="2"
                android:minLines="2"
                android:lineSpacingMultiplier="1.0"
                android:includeFontPadding="false"
                android:ellipsize="end"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="@string/settings_button_text" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
