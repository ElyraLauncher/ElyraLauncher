<?xml version="1.0" encoding="utf-8"?>
<!--
    Elyra Home Edit Mode fullscreen overlay.

    Added directly to DragLayer as a plain (non-floating-view) child; visibility and
    animation are driven entirely by ElyraHomeEditModeController reacting to
    LauncherState.EDIT_MODE transitions. The scaled/dimmed workspace itself is handled
    by EditModeState (see LauncherState#EDIT_MODE) — this overlay only supplies the
    top/bottom chrome plus an extra scrim for a guaranteed, theme-independent dim.

    The middle area (between the top and bottom bars) is the scrim itself, so tapping
    the dimmed workspace exits edit mode the same way Done/back do.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/elyra_home_edit_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:contentDescription="@string/elyra_home_edit_panel_description"
    android:visibility="gone">

    <View
        android:id="@+id/elyra_home_edit_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/elyra_home_edit_scrim"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:id="@+id/elyra_home_edit_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp">

        <!--
            Group is a placeholder for a not-yet-implemented icon-grouping feature.
            Visually present (per UX spec) but permanently disabled/non-clickable — no
            fake behavior is wired to it. Enable once real grouping exists.
        -->
        <TextView
            android:id="@+id/elyra_home_edit_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="96dp"
            android:minHeight="48dp"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/elyra_home_edit_group_bg"
            android:clickable="false"
            android:focusable="false"
            android:alpha="0.45"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:text="@string/elyra_home_edit_group_button_text" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/elyra_home_edit_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="96dp"
            android:minHeight="48dp"
            android:gravity="center"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/elyra_home_edit_done_bg"
            android:clickable="true"
            android:focusable="true"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:text="@string/elyra_home_edit_done_button_text" />
    </LinearLayout>

    <!--
        No card/panel background: actions sit directly over the dimmed workspace/wallpaper
        (elyra_home_edit_scrim), per UX spec — this must not read as a popup.
    -->
    <LinearLayout
        android:id="@+id/elyra_home_edit_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:paddingTop="22dp"
        android:paddingBottom="22dp">

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_widget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:tint="@android:color/white"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_widget" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="@string/widget_button_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_wallpaper"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:tint="@android:color/white"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_palette" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="@string/styles_wallpaper_button_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:tint="@android:color/white"
                android:importantForAccessibility="no"
                android:src="@drawable/elyra_ic_grid" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="@string/elyra_home_edit_layout_button_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:tint="@android:color/white"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_setting" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="@string/settings_button_text" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
