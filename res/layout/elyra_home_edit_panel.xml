<?xml version="1.0" encoding="utf-8"?>
<!--
    Elyra Home Edit Mode bottom action panel.
    Root is the ElyraHomeEditPanel floating view; it manually lays out mContent
    bottom-centered (see ElyraHomeEditPanel#onLayout), so root-level layout params here
    are not used by the LinearLayout arrangement logic.
-->
<com.android.launcher3.elyra.homeedit.ElyraHomeEditPanel
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:contentDescription="@string/elyra_home_edit_panel_description">

    <LinearLayout
        android:id="@+id/elyra_home_edit_panel_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        android:background="@drawable/elyra_home_edit_panel_bg"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_wallpaper"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:tint="@android:color/white"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_palette" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:text="@string/styles_wallpaper_button_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_widget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:tint="@android:color/white"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_widget" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:text="@string/widget_button_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:tint="@android:color/white"
                android:importantForAccessibility="no"
                android:src="@drawable/elyra_ic_grid" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:text="@string/elyra_home_edit_layout_button_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/elyra_home_edit_action_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:tint="@android:color/white"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_setting" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:text="@string/settings_button_text" />
        </LinearLayout>

    </LinearLayout>
</com.android.launcher3.elyra.homeedit.ElyraHomeEditPanel>
