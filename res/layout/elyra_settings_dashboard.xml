<?xml version="1.0" encoding="utf-8"?>
<!-- Elyra settings main dashboard — pure ScrollView, no overlay, no animation. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none"
    android:background="@color/elyra_settings_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Large title — scrolls with content -->
        <TextView
            android:id="@+id/large_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_button_text"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/elyra_hero_text_primary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp" />

        <!-- Pusat Elyra hero card -->
        <include layout="@layout/elyra_settings_hero_card" />

        <!-- ── Pengaturan utama ──────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/elyra_settings_section_main"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.10"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/card_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/elyra_settings_card_bg">

            <include
                android:id="@+id/row_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

        </LinearLayout>

        <!-- ── Pengaturan cepat ─────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/elyra_settings_section_quick"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.10"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/card_quick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/elyra_settings_card_bg">

            <include
                android:id="@+id/row_notification_dots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

            <View
                android:id="@+id/divider_notif_add"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF"
                android:layout_marginStart="56dp" />

            <include
                android:id="@+id/row_add_to_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

            <View
                android:id="@+id/divider_add_rotation"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF"
                android:layout_marginStart="56dp" />

            <include
                android:id="@+id/row_rotation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

        </LinearLayout>

        <!-- ── Personalisasi ────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/elyra_settings_section_personalize"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.10"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/card_personalize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/elyra_settings_card_bg">

            <include
                android:id="@+id/row_sec_dock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF"
                android:layout_marginStart="56dp" />

            <include
                android:id="@+id/row_sec_drawer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF"
                android:layout_marginStart="56dp" />

            <include
                android:id="@+id/row_sec_folder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF"
                android:layout_marginStart="56dp" />

            <include
                android:id="@+id/row_sec_appearance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF"
                android:layout_marginStart="56dp" />

            <include
                android:id="@+id/row_sec_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF"
                android:layout_marginStart="56dp" />

            <include
                android:id="@+id/row_sec_editmode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

        </LinearLayout>

        <!-- Bottom breathing room -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
