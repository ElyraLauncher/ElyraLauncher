<?xml version="1.0" encoding="utf-8"?>
<!--
    Elyra settings main dashboard.
    Replaces the default PreferenceScreen as the root content of SettingsActivity.
    Inflated by ElyraSettingsDashboardFragment.

    Sections:
      - Pengaturan utama  : nav rows for major feature areas (only show if destination is real)
      - Pengaturan cepat  : functional toggle/nav rows for quick access
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/elyra_settings_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Pusat Elyra hero card -->
        <include layout="@layout/elyra_settings_hero_card" />

        <!-- ═══════════════════════════════════════
             SECTION: Pengaturan utama
             Only rows with real functional destinations.
             ═══════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/elyra_settings_section_main"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.10"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/card_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/elyra_settings_card_bg"
            android:clipToOutline="true">

            <!-- Layar Utama — navigates to LauncherSettingsFragment (functional) -->
            <include
                android:id="@+id/row_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════
             SECTION: Pengaturan cepat
             Direct toggles/nav rows for functional system prefs.
             ═══════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/elyra_settings_section_quick"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.10"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/card_quick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/elyra_settings_card_bg"
            android:clipToOutline="true">

            <!-- Notification Dots — nav row opening system notification settings -->
            <include
                android:id="@+id/row_notification_dots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

            <View
                android:id="@+id/divider_notif_add"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF"
                android:layout_marginStart="56dp" />

            <!-- Add to Home — toggle row -->
            <include
                android:id="@+id/row_add_to_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

            <!-- Divider hidden programmatically when rotation row is hidden -->
            <View
                android:id="@+id/divider_add_rotation"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF"
                android:layout_marginStart="56dp" />

            <!-- Rotation — toggle row, phones only -->
            <include
                android:id="@+id/row_rotation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/elyra_settings_row" />

        </LinearLayout>

        <!-- Bottom breathing room -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>

</ScrollView>
