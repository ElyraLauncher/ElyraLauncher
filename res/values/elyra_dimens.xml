<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Hotseat dock surface dimensions -->

    <!-- Large radius for pill/stadium card aesthetic -->
    <dimen name="elyra_dock_corner_radius">36dp</dimen>

    <!-- Space between screen edge and pill edge (~88–90% screen width) -->
    <dimen name="elyra_dock_horizontal_margin">22dp</dimen>

    <!-- Gap above visible pill from Hotseat view top edge; 0 maximises pill height -->
    <dimen name="elyra_dock_top_gap">0dp</dimen>

    <!-- Minimum gap below pill when nav bar reports zero height -->
    <dimen name="elyra_dock_bottom_gap">4dp</dimen>

    <!-- Minimum breathing room between pill bottom and gesture nav bar -->
    <dimen name="elyra_dock_bottom_margin">12dp</dimen>

    <!-- Horizontal padding inside the pill from pill edge to first icon cell -->
    <dimen name="elyra_dock_padding_horizontal">16dp</dimen>

    <!-- Informational: target pill card height (actual value computed from DeviceProfile) -->
    <dimen name="elyra_dock_height">80dp</dimen>

    <!-- Informational: target icon size (actual value from DeviceProfile.hotseatCellHeightPx) -->
    <dimen name="elyra_dock_icon_size">56dp</dimen>

    <!-- Informational: minimum icon cell width for 4-icon layout -->
    <dimen name="elyra_dock_icon_cell_min_width">64dp</dimen>

    <!-- Informational: gap between icon cells (actual from DeviceProfile.hotseatBorderSpace) -->
    <dimen name="elyra_dock_icon_gap">14dp</dimen>

    <!-- Folder surface -->
    <dimen name="elyra_folder_corner_radius">24dp</dimen>

    <!-- All-apps search bar -->
    <dimen name="elyra_search_corner_radius">16dp</dimen>

    <!-- All-apps drawer top handle -->
    <dimen name="elyra_drawer_top_corner_radius">28dp</dimen>

    <!-- Settings hero card -->
    <dimen name="elyra_hero_card_corner_radius">20dp</dimen>
    <dimen name="elyra_hero_card_padding">20dp</dimen>
    <dimen name="elyra_hero_card_margin_horizontal">16dp</dimen>
    <dimen name="elyra_hero_action_corner_radius">14dp</dimen>

    <!-- Smart region (home screen overlay) -->
    <dimen name="elyra_smart_region_padding">20dp</dimen>
    <dimen name="elyra_smart_region_corner_radius">18dp</dimen>
    <dimen name="elyra_smart_identity_text_size">32sp</dimen>
    <dimen name="elyra_smart_greeting_text_size">14sp</dimen>
    <dimen name="elyra_smart_subtitle_text_size">12sp</dimen>

    <!-- Search trigger -->
    <dimen name="elyra_search_trigger_height">40dp</dimen>
    <dimen name="elyra_search_trigger_corner_radius">20dp</dimen>
    <dimen name="elyra_search_trigger_margin_horizontal">20dp</dimen>
    <!-- Compact fixed width — trigger lives near page indicator, not full-width bar -->
    <dimen name="elyra_search_trigger_width">240dp</dimen>

    <!-- Folder style: grid counts are stored as ints, but corner radii live here -->
    <dimen name="elyra_folder_style_corner_radius_standard">24dp</dimen>
    <dimen name="elyra_folder_style_corner_radius_large">28dp</dimen>
    <dimen name="elyra_folder_style_corner_radius_wide">20dp</dimen>
    <dimen name="elyra_folder_style_corner_radius_tall">20dp</dimen>

    <!-- Folder style dimensions (informational; actual size derived from numFolderRows/Cols × cell size) -->
    <dimen name="elyra_folder_preview_padding">12dp</dimen>
    <dimen name="elyra_folder_preview_icon_gap">6dp</dimen>
</resources>
