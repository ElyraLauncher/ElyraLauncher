<?xml version="1.0" encoding="utf-8"?>
<!--
    Group pill surface for Elyra Home Edit Mode top bar.
    Uses a Material 3 dynamic surface-container tone (adaptive light/dark) instead of a
    hardcoded translucent white. Paired with clickable="false" in the layout since real
    icon grouping is not implemented yet — it reads as a present-but-inactive control.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/materialColorSurfaceContainerHigh" />
    <corners android:radius="20dp" />
</shape>
